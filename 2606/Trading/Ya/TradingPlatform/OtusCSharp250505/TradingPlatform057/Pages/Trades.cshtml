@page
@model TradingPlatform.Pages.TradesModel
@{
    ViewData["Title"] = "Trades";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>📈 Trades</h1>
        <div>
            <span class="badge bg-info" id="tradesCountBadge">Total: @Model.Trades.TotalCount</span>
            <a href="/Trades" class="btn btn-outline-secondary btn-sm ms-2">Manual Refresh</a>
            <!-- Кнопка автообновления -->
            <button id="autoRefreshBtn" class="btn btn-outline-primary btn-sm ms-2">
                <i class="bi bi-play-circle"></i> Auto Refresh
                <span id="autoRefreshStatus" class="ms-1">(OFF)</span>
            </button>
        </div>
    </div>

    <!-- Фильтры -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Filters</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3" id="filterForm">
                <div class="col-md-4">
                    <label class="form-label">Ticker</label>
                    <input type="text"
                           class="form-control"
                           name="selectedTicker"
                           id="tickerFilter"
                           value="@Model.SelectedTicker"
                           placeholder="Enter ticker (e.g., AAA)">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Strategy</label>
                    <input type="text"
                           class="form-control"
                           name="selectedStrategy"
                           id="strategyFilter"
                           value="@Model.SelectedStrategy"
                           placeholder="Enter strategy (e.g., AAA_05s)">
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Apply Filters</button>
                    <button type="button" class="btn btn-outline-secondary" id="clearFiltersBtn">Clear</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Таблица сделок -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                Recent Trades
                <small class="text-muted ms-2" id="lastUpdateText">
                    Last update: @DateTime.Now.ToString("HH:mm:ss")
                </small>
            </h5>
            <div>
                <span class="badge bg-info">Page @Model.Trades.PageNumber of @Model.Trades.TotalPages</span>
                <span class="badge bg-success ms-2" id="newTradesBadge" style="display: none;">+0 new</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 600px;">
                <table class="table table-hover mb-0" id="tradesTable">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Time <small class="text-muted">(newest first)</small></th>
                            <th>Ticker</th>
                            <th>Strategy</th>
                            <th>Side</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Volume</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="tradesTableBody">
                        @foreach (var trade in Model.Trades.Items.OrderByDescending(t => t.Timestamp))
                        {
                            <tr>
                                <td>
                                    @trade.Timestamp.ToString("HH:mm:ss")
                                    @if ((DateTime.Now - trade.Timestamp).TotalSeconds < 10)
                                    {
                                        <span class="badge bg-warning ms-1">NEW</span>
                                    }
                                </td>
                                <td><strong>@trade.Ticker</strong></td>
                                <td><small class="text-muted">@trade.Strategy</small></td>
                                <td>
                                    <span class="badge @(trade.Side == "Buy" ? "bg-success" : "bg-danger")">
                                        @trade.Side
                                    </span>
                                </td>
                                <td>@trade.Price.ToString("N2")</td>
                                <td>@trade.Quantity.ToString("N0")</td>
                                <td>@trade.Volume.ToString("N2")</td>
                                <td><span class="badge bg-info">@trade.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Trades.TotalPages > 1)
        {
            <div class="card-footer">
                <nav>
                    <ul class="pagination justify-content-center mb-0" id="pagination">
                        @for (int i = 1; i <= Model.Trades.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Trades.PageNumber ? "active" : "")">
                                <a class="page-link"
                                   href="/Trades?pageNumber=@i&selectedTicker=@Model.SelectedTicker&selectedStrategy=@Model.SelectedStrategy"
                                   data-page="@i">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        let autoRefreshEnabled = false;
        let refreshInterval = null;
        const REFRESH_INTERVAL = 5000; // 5 секунд

        // Элементы DOM
        let autoRefreshBtn = null;
        let autoRefreshStatus = null;
        let tradesCountBadge = null;
        let lastUpdateText = null;
        let newTradesBadge = null;
        let tradesTable = null;
        let tradesTableBody = null;

        // Простая анимация через изменение opacity
        function animateTableRefresh() {
            if (tradesTable) {
                // Сохраняем текущую прозрачность
                const originalOpacity = tradesTable.style.opacity || '1';

                // Анимация: быстрое затемнение и осветление
                tradesTable.style.transition = 'opacity 0.15s ease-in-out';
                tradesTable.style.opacity = '0.8';

                setTimeout(() => {
                    tradesTable.style.opacity = '1';
                }, 150);

                // Возвращаем нормальное состояние
                setTimeout(() => {
                    tradesTable.style.transition = '';
                    tradesTable.style.opacity = originalOpacity;
                }, 300);
            }
        }

        // Обновление времени последнего обновления
        function updateLastUpdateTime() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('ru-RU', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });

            if (lastUpdateText) {
                lastUpdateText.textContent = `Last update: ${timeStr}`;
            }
        }

        // Обновление счетчика новых сделок
        let newTradesCount = 0;
        function updateNewTradesCount(increment = 0) {
            if (increment > 0) {
                newTradesCount += increment;
                newTradesBadge.textContent = `+${newTradesCount} new`;
                newTradesBadge.style.display = 'inline';

                // Через 5 секунд сбрасываем счетчик
                setTimeout(() => {
                    newTradesCount = 0;
                    newTradesBadge.style.display = 'none';
                }, 5000);
            }
        }

        // Загрузка данных через API
        async function loadTradesData() {
            try {
                const ticker = document.getElementById('tickerFilter').value || '';
                const strategy = document.getElementById('strategyFilter').value || '';
                const page = 1; // ВСЕГДА первая страница при автообновлении, чтобы видеть новые сделки

                console.log(`Loading trades: ticker=${ticker}, strategy=${strategy}, page=${page}`);

                const response = await fetch(`/api/trading/trades?ticker=${encodeURIComponent(ticker)}&strategy=${encodeURIComponent(strategy)}&page=${page}`);

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const data = await response.json();
                console.log('API response:', data);

                // Обновляем таблицу если данные получены
                if (data && data.items && Array.isArray(data.items)) {
                    updateTradesTable(data.items);
                }

                // Обновляем счетчик
                if (data && data.totalCount !== undefined) {
                    tradesCountBadge.textContent = `Total: ${data.totalCount}`;
                }

                // Обновляем время
                updateLastUpdateTime();

                // Анимируем таблицу
                animateTableRefresh();

                // Обновляем счетчик новых сделок (если есть новые)
                if (data.items && data.items.length > 0) {
                    // Проверяем, есть ли действительно новые сделки
                    // Пока просто увеличиваем на 1 для демонстрации
                    updateNewTradesCount(1);
                }

                console.log('✅ Данные успешно обновлены');

            } catch (error) {
                console.error('❌ Ошибка загрузки данных:', error);
            }
        }

        // Обновление таблицы сделок
        function updateTradesTable(trades) {
            if (!tradesTableBody) return;

            // Очищаем таблицу
            tradesTableBody.innerHTML = '';

            // Сортируем сделки по времени (новые сверху)
            trades.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));

            // Добавляем сделки в таблицу
            trades.forEach(trade => {
                const row = document.createElement('tr');

                // Форматируем время
                const timestamp = new Date(trade.timestamp);
                const timeStr = timestamp.toLocaleTimeString('ru-RU', {
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit'
                });

                // Проверяем, новая ли это сделка (последние 10 секунд)
                const isNew = (Date.now() - timestamp.getTime()) < 10000;

                // Определяем класс для Side
                const sideClass = trade.side === 'Buy' ? 'bg-success' : 'bg-danger';

                row.innerHTML = `
                    <td>
                        ${timeStr}
                        ${isNew ? '<span class="badge bg-warning ms-1">NEW</span>' : ''}
                    </td>
                    <td><strong>${trade.ticker}</strong></td>
                    <td><small class="text-muted">${trade.strategy}</small></td>
                    <td>
                        <span class="badge ${sideClass}">${trade.side}</span>
                    </td>
                    <td>${trade.price.toFixed(2)}</td>
                    <td>${trade.quantity.toLocaleString()}</td>
                    <td>${(trade.price * trade.quantity).toFixed(2)}</td>
                    <td><span class="badge bg-info">${trade.status}</span></td>
                `;

                // Добавляем анимацию для новых сделок
                if (isNew) {
                    row.style.backgroundColor = 'rgba(255, 255, 0, 0.1)';
                    row.style.animation = 'fadeOutBackground 2s forwards';

                    // Добавляем стиль для анимации
                    if (!document.querySelector('#fadeOutStyle')) {
                        const style = document.createElement('style');
                        style.id = 'fadeOutStyle';
                        style.textContent = `
                            @@keyframes fadeOutBackground {
                                from { background-color: rgba(255, 255, 0, 0.1); }
                                to { background-color: transparent; }
                            }
                        `;
                        document.head.appendChild(style);
                    }
                }

                tradesTableBody.appendChild(row);
            });
        }

        // Переключение автообновления
        function toggleAutoRefresh() {
            autoRefreshEnabled = !autoRefreshEnabled;

            if (autoRefreshEnabled) {
                // Включаем автообновление
                autoRefreshBtn.innerHTML = '<i class="bi bi-pause-circle"></i> Auto Refresh';
                autoRefreshBtn.classList.remove('btn-outline-primary');
                autoRefreshBtn.classList.add('btn-primary');
                autoRefreshStatus.textContent = '(ON)';

                // Запускаем автообновление
                refreshInterval = setInterval(() => {
                    console.log('Auto-refreshing...');
                    loadTradesData();
                }, REFRESH_INTERVAL);

                // Немедленная загрузка данных
                loadTradesData();

            } else {
                // Выключаем автообновление
                autoRefreshBtn.innerHTML = '<i class="bi bi-play-circle"></i> Auto Refresh';
                autoRefreshBtn.classList.remove('btn-primary');
                autoRefreshBtn.classList.add('btn-outline-primary');
                autoRefreshStatus.textContent = '(OFF)';

                // Останавливаем автообновление
                if (refreshInterval) {
                    clearInterval(refreshInterval);
                    refreshInterval = null;
                }
            }
        }

        // Очистка фильтров
        function clearFilters() {
            document.getElementById('tickerFilter').value = '';
            document.getElementById('strategyFilter').value = '';

            // Если автообновление включено, загружаем данные
            if (autoRefreshEnabled) {
                loadTradesData();
            } else {
                // Иначе перезагружаем страницу
                window.location.href = '/Trades';
            }
        }

        // Инициализация
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Trades page loaded');

            // Инициализируем элементы
            autoRefreshBtn = document.getElementById('autoRefreshBtn');
            autoRefreshStatus = document.getElementById('autoRefreshStatus');
            tradesCountBadge = document.getElementById('tradesCountBadge');
            lastUpdateText = document.getElementById('lastUpdateText');
            newTradesBadge = document.getElementById('newTradesBadge');
            tradesTable = document.getElementById('tradesTable');
            tradesTableBody = document.getElementById('tradesTableBody');

            // Назначаем обработчики
            if (autoRefreshBtn) {
                autoRefreshBtn.addEventListener('click', toggleAutoRefresh);
            }

            if (document.getElementById('clearFiltersBtn')) {
                document.getElementById('clearFiltersBtn').addEventListener('click', clearFilters);
            }

            // Обработчик формы фильтров (предотвращаем перезагрузку страницы)
            if (document.getElementById('filterForm')) {
                document.getElementById('filterForm').addEventListener('submit', function(e) {
                    e.preventDefault();
                    // Если автообновление включено, используем его для загрузки данных
                    if (autoRefreshEnabled) {
                        loadTradesData();
                    } else {
                        // Иначе отправляем форму обычным способом
                        this.submit();
                    }
                });
            }

            // Обновляем время при загрузке
            updateLastUpdateTime();

            // Автоматически включаем автообновление при загрузке (опционально)
            // toggleAutoRefresh();
        });

        // Очистка при закрытии страницы
        window.addEventListener('beforeunload', function() {
            if (refreshInterval) {
                clearInterval(refreshInterval);
            }
        });
    </script>
}
