@page
@model QuotesClientRazor01.Pages.IndexModel
@{
    ViewData["Title"] = $"Stock Quotes - {Model.ChannelDisplayName}";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center" style="background-color: @Model.ChannelColor; color: white;">
                    <h3 class="mb-0">📊 @Model.ChannelDisplayName</h3>
                    <div>
                        <span class="badge bg-light text-dark me-2">Channel: @Model.ChannelName</span>
                        <span class="badge bg-light text-dark">Last Update: @DateTime.Now.ToString("HH:mm:ss")</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Ticker</th>
                                    <th>Last Price</th>
                                    <th>Change</th>
                                    <th>Change %</th>
                                    <th>Bid</th>
                                    <th>Ask</th>
                                    <th>Volume</th>
                                    <th>Timestamp</th>
                                </tr>
                            </thead>
                            <tbody id="quotesTableBody">
                                @foreach (var quote in Model.Quotes.OrderBy(q => q.Ticker))
                                {
                                    <tr id="row-@quote.Ticker" class="quote-row">
                                        <td><strong>@quote.Ticker</strong></td>
                                        <td class="last-price" data-ticker="@quote.Ticker">@quote.Last.ToString("C")</td>
                                        <td class="change" data-ticker="@quote.Ticker" style="color: @(quote.Change >= 0 ? "green" : "red")">
                                            @(quote.Change >= 0 ? "+" : "")@quote.Change.ToString("C")
                                        </td>
                                        <td class="change-percent" data-ticker="@quote.Ticker" style="color: @(quote.ChangePercent >= 0 ? "green" : "red")">
                                            @(quote.ChangePercent >= 0 ? "+" : "")@quote.ChangePercent.ToString("F2")%
                                        </td>
                                        <td>@quote.Bid.ToString("C")</td>
                                        <td>@quote.Ask.ToString("C")</td>
                                        <td>@quote.Volume.ToString("N0")</td>
                                        <td>@quote.Timestamp.ToString("HH:mm:ss.fff")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <div class="alert alert-info">
                                <strong>Status:</strong> <span id="connectionStatus" class="badge bg-success">Connected</span>
                            </div>
                        </div>
                        <div class="col-md-6 text-end">
                            <button class="btn btn-primary" onclick="location.reload()">↻ Refresh</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/quoteHub")
            .withAutomaticReconnect()
            .build();

        connection.on("QuoteUpdated", (quote) => {
            updateQuoteRow(quote);
        });

        connection.start().catch(err => console.error(err.toString()));

        function updateQuoteRow(quote) {
            const row = document.getElementById(`row-${quote.ticker}`);
            if (row) {
                // Обновляем ячейки с анимацией
                updateCellWithAnimation(row.querySelector('.last-price'), formatCurrency(quote.last));
                updateCellWithAnimation(row.querySelector('.change'), formatChange(quote.change, true));
                updateCellWithAnimation(row.querySelector('.change-percent'), formatChange(quote.changePercent, false));

                // Обновляем остальные ячейки
                row.cells[4].textContent = formatCurrency(quote.bid);
                row.cells[5].textContent = formatCurrency(quote.ask);
                row.cells[6].textContent = formatVolume(quote.volume);
                row.cells[7].textContent = new Date(quote.timestamp).toLocaleTimeString('ru-RU', {
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    fractionalSecondDigits: 3
                });
            }
        }

        function updateCellWithAnimation(cell, newValue) {
            if (cell && cell.textContent !== newValue) {
                cell.style.transition = 'background-color 0.5s';
                cell.style.backgroundColor = '#d4edda';
                cell.textContent = newValue;
                setTimeout(() => {
                    cell.style.backgroundColor = '';
                }, 500);
            }
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('ru-RU', {
                style: 'currency',
                currency: 'USD',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(value);
        }

        function formatChange(value, isCurrency) {
            if (isCurrency) {
                return (value >= 0 ? '+' : '') + formatCurrency(Math.abs(value));
            } else {
                return (value >= 0 ? '+' : '') + value.toFixed(2) + '%';
            }
        }

        function formatVolume(value) {
            return new Intl.NumberFormat('ru-RU').format(value);
        }
    </script>

    <style>
        .quote-row {
            transition: background-color 0.3s;
        }

            .quote-row:hover {
                background-color: #f8f9fa !important;
            }

        .last-price, .change, .change-percent {
            font-weight: bold;
            transition: background-color 0.5s;
        }

        .badge {
            font-size: 0.9rem;
            padding: 8px 12px;
        }
    </style>
}